,"source":["# OpenAI 클래스 초기화\n","llm = OpenAI(temperature=0.4, openai_api_key=openai_api_key)\n","\n","# RetrievalQA 체인 생성\n","qa_chain = RetrievalQA.from_chain_type(\n","    llm=llm,\n","    chain_type=\"stuff\",\n","    retriever=vector_store.as_retriever(search_kwargs={\"k\": 5}),\n","    return_source_documents=True,\n","    chain_type_kwargs={\"prompt\": PROMPT}\n",")"],"metadata":{"id":"-jfW3OxybgvN"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 1. 메타데이터 수집 함수 (get_unique_metadata)"],"metadata":{"id":"vlWHXv8-l3Rl"}},{"cell_type":"code","source":["def get_unique_metadata():\n","    try:\n","        categories = set()\n","        diseases = set()\n","        intents = set()\n","        offset = 0  # 오프셋 초기화\n","        limit = 1000  # 한 번에 가져올 문서 수\n","\n","        while True:\n","            response = client.scroll(\n","                collection_name=COLLECTION_NAME,\n","                scroll_filter=None,\n","                limit=limit,\n","                with_payload=True,\n","                with_vectors=False,\n","                offset=offset  # 오프셋을 사용한 페이징 처리\n","            )\n","\n","            if not response or not response[0]:\n","                break\n","\n","            for point in response[0]:\n","                category = point.payload.get(\"질병_카테고리\")\n","                disease = point.payload.get(\"질병\")\n","                intent = point.payload.get(\"의도\")\n","\n","                if category:\n","                    categories.add(category)\n","                if disease:\n","                    diseases.add(disease)\n","                if intent:\n","                    intents.add(intent)\n","\n","            # 다음 페이지를 위해 오프셋 증가\n","            offset += limit\n","\n","            # 더 이상 가져올 데이터가 없으면 중지\n","            if len(response[0]) < limit:\n","                break\n","\n","        return list(categories), list(diseases), list(intents)\n","    except Exception as e:\n","        logging.error(f\"메타데이터 가져오기 중 오류 발생: {str(e)}\")\n","        return [], [], []\n"],"metadata":{"id":"ZJb2PupsbjPB"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 2. 쿼리와 메타데이터 매칭 함수 (match_metadata) -> 문제??"],"metadata":{"id":"4Otn4IwdmBQ2"}},{"cell_type":"code","source":["import difflib\n","import logging\n","\n","def normalize_string(s):\n","    return s.lower().strip()\n","\n","def match_metadata(query, categories, diseases, intents):\n","    query_lower = normalize_string(query)\n","    logging.info(f\"정규화된 쿼리: {query_lower}\")\n","\n","\n","    # 정규화된 메타데이터 세트 생성\n","    normalized_categories = {normalize_string(cat) for cat in categories}\n","    normalized_diseases = {normalize_string(dis) for dis in diseases}\n","    normalized_intents = {normalize_string(intent) for intent in intents}\n","\n","\n","    # 쿼리 단어 단위로 분리하여 매칭 시도\n","    query_words = query_lower.split()\n","    matched_category = []\n","    matched_disease = []\n","    matched_intent = []\n","\n","    for word in query_words:\n","        if not matched_category:\n","            matched_category = difflib.get_close_matches(word, list(normalized_categories), n=1, cutoff=0.3)\n","        if not matched_disease:\n","            matched_disease = difflib.get_close_matches(word, list(normalized_diseases), n=1, cutoff=0.3)\n","        if not matched_intent:\n","            matched_intent = difflib.get_close_matches(word, list(normalized_intents), n=1, cutoff=0.3)\n","\n","    # 매칭 결과 로그 기록\n","    logging.debug(f\"매칭된 카테고리: {matched_category}\")\n","    logging.debug(f\"매칭된 질병: {matched_disease}\")\n","    logging.debug(f\"매칭된 의도: {matched_intent}\")\n","\n","    category = matched_category[0] if matched_category else None\n","    disease = matched_disease[0] if matched_disease else None\n","    intent = matched_intent[0] if matched_intent else None\n","\n","    # 의도가 추출되지 않았을 때 경고 로그 기록\n","    if not intent:\n","        # logging.warning(f\" 쿼리: {query} / 의도 목록: {intents}\")\n","        pass\n","\n","    logging.debug(f\"최종 추출된 메타데이터: 카테고리={category}, 질병={disease}, 의도={intent}\")\n","    return category, disease, intent\n","\n","# 로깅 설정\n","logging.basicConfig(level=logging.DEBUG)\n","\n","# 예시 메타데이터 세트\n","# DISEASE_CATEGORIES = [\"응급질환\", \"순환기질환\"]\n","# DISEASES = [\"고혈압\", \"식중독\", \"두통\"]\n","# INTENTS = [\"검진\", \"치료\", \"예방\", \"증상\"]\n","\n","# # 테스트 쿼리\n","# query = \"응급한 고혈압 증상에 대해 알고 싶습니다.\"\n","\n","# # 메타데이터 매칭 실행\n","# category, disease, intent = match_metadata(query, DISEASE_CATEGORIES, DISEASES, INTENTS)\n","\n","# # 결과 출력\n","# print(f\"카테고리: {category}\")\n","# print(f\"질병: {disease}\")\n","# print(f\"의도: {intent}\")\n"],"metadata":{"id":"ckdWR0xI0M8p"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# def match_metadata(query, categories, diseases, intents):\n","#     query_lower = query.lower()\n","#     category = next((cat for cat in categories if cat.lower() in query_lower), None)\n","#     disease = next((dis for dis in diseases if dis.lower() in query_lower), None)\n","#     intent = next((intent for intent in intents if intent.lower() in query_lower), None)\n","#     logging.debug(f\"추출된 메타데이터: 카테고리={category}, 질병={disease}, 의도={intent}\")\n","#     return category, disease, intent"],"metadata":{"id":"7fB96-wx1ACe"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 3. 확장된 쿼리 생성 함수 (expand_query)"],"metadata":{"id":"1I_1J69EmGAR"}},{"cell_type":"code","source":["from typing import List\n","import logging\n","\n","def expand_query(query: str) -> List[str]:\n","    expanded_queries = [query]\n","\n","    synonyms = {\n","        \"증상\": [\"징후\", \"병증\", \"증세\"],\n","        \"치료\": [\"처치\", \"요법\", \"치료법\"],\n","        \"예방\": [\"방지\", \"예방책\", \"예방법\"],\n","        \"통증\": [\"아픔\", \"고통\", \"불편함\"],\n","    }\n","\n","    words = query.split()\n","    for word in words:\n","        if word in synonyms:\n","            for syn in synonyms[word]:\n","                new_query = query.replace(word, syn)\n","                expanded_queries.append(new_query)\n","\n","    # 메타데이터를 기반으로 쿼리 확장\n","    category, disease, intent = match_metadata(query, DISEASE_CATEGORIES, DISEASES, INTENTS)\n","    if category:\n","        expanded_queries.append(f\"{query} {category}\")\n","    if disease:\n","        expanded_queries.append(f\"{query} {disease}\")\n","    if intent:\n","        expanded_queries.append(f\"{query} {intent}\")\n","\n","    logging.debug(f\"확장된 쿼리: {expanded_queries}\")\n","    return list(set(expanded_queries))\n"],"metadata":{"id":"Hec1SbiFmIWQ"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 4. BM25 검색 함수 (bm25_search)"],"metadata":{"id":"kqs1aL7GmJSl"}},{"cell_type":"code","source":["def bm25_search(query: str, documents: List[Any], top_k: int = 5) -> List[Any]:\n","    if not documents:\n","        logging.warning(\"BM25 검색: 문서 목록이 비어 있습니다.\")\n","        return []\n","\n","    try:\n","        # BM25 알고리즘을 위해 payload의 content 필드를 사용\n","        corpus = [doc['content'] for doc in documents if 'content' in doc and doc['content'].strip()]\n","        if not corpus:\n","            logging.warning(\"BM25 검색: 모든 문서의 내용이 비어 있습니다.\")\n","            return []\n","\n","        bm25 = BM25Okapi(corpus)\n","        scores = bm25.get_scores(query.split())\n","\n","        # 점수에 따라 문서 정렬 및 상위 top_k 문서 선택\n","        top_results = sorted(zip(documents, scores), key=lambda x: x[1], reverse=True)[:top_k]\n","\n","        return [doc for doc, score in top_results]\n","    except Exception as e:\n","        logging.error(f\"BM25 검색 중 오류 발생: {str(e)}\")\n","        return []\n"],"metadata":{"id":"FLrzbHY3bqRB"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 5. 벡터 검색 함수 (vector_search)"],"metadata":{"id":"tYLp7CZ3mRnv"}},{"cell_type":"code","source":["def vector_search(query, documents, top_k=5):\n","    if not documents:\n","        logging.warning(\"벡터 검색: 문서 목록이 비어 있습니다.\")\n","        return []\n","\n","    try:\n","        query_embedding = st_model.encode([query])[0]\n","        doc_embeddings = st_model.encode([doc.payload.get('답변', '') for doc in documents])\n","\n","        similarities = cosine_similarity([query_embedding], doc_embeddings)[0]\n","\n","        top_results = sorted(zip(documents, similarities), key=lambda x: x[1], reverse=True)[:top_k]\n","        valid_results = [doc for doc, score in top_results if doc.payload.get('답변', '').strip()]\n","\n","        return valid_results\n","    except Exception as e:\n","        logging.error(f\"벡터 검색 중 오류 발생: {str(e)}\")\n","        return []\n"],"metadata":{"id":"gR5e7kQ-mUju"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 6. 앙상블 검색 함수 (ensemble_search)"],"metadata":{"id":"wib70qXfmW6r"}},{"cell_type":"code","source":["def ensemble_search(query: str, documents: List[Any], top_k: int = 5) -> List[Any]:\n","    if not documents:\n","        logging.warning(\"앙상블 검색: 문서 목록이 비어 있습니다.\")\n","        return []\n","\n","    try:\n","        bm25_results = bm25_search(query, documents, top_k)\n","        vector_results = vector_search(query, documents, top_k)\n","\n","        combined_results = list(dict.fromkeys(bm25_results + vector_results))\n","\n","        if not combined_results:\n","            logging.warning(\"앙상블 검색: 결과가 없습니다.\")\n","            return []\n","\n","        # `payload`의 필드를 사용하여 유효성 검사 및 처리\n","        valid_results = []\n","        for result in combined_results:\n","            content = result.payload.get('답변', None)\n","            if content and content.strip():\n","                valid_results.append(result)\n","\n","        if not valid_results:\n","            logging.warning(\"유효한 검색 결과가 없습니다.\")\n","            return []\n","\n","        return valid_results[:top_k]\n","    except Exception as e:\n","        logging.error(f\"앙상블 검색 중 오류 발생: {str(e)}\")\n","        return []\n"],"metadata":{"id":"kmbGuEIwmZpv"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 7. GPT-4 응답 생성 함수 (generate_gpt4_response)"],"metadata":{"id":"FH2xQ0CnmcEf"}},{"cell_type":"code","source":["def generate_gpt4_response(query: str, context: str = None, metadata: Dict[str, str] = None) -> str:\n","    try:\n","        system_message = \"You are a helpful assistant specializing in medical information. Provide accurate and concise answers based on the given context and metadata.\"\n","        user_message = f\"Question: {query}\\n\\nContext: {context}\\n\\nMetadata: {metadata}\"\n","\n","        response = openai_client.chat.completions.create(\n","            model=\"gpt-4-turbo-preview\",\n","            messages=[\n","                {\"role\": \"system\", \"content\": system_message},\n","                {\"role\": \"user\", \"content\": user_message}\n","            ],\n","            max_tokens=150,\n","            n=1,\n","            stop=None,\n","            temperature=0.7,\n","        )\n","\n","        # 기본 답변에 메타데이터 추가\n","        final_response = response.choices[0].message.content.strip()\n","        if metadata:\n","            metadata_str = \"\\n\\n[메타데이터]\\n\"\n","            for key, value in metadata.items():\n","                metadata_str += f\"{key}: {value}\\n\"\n","            final_response += metadata_str\n","\n","        return final_response\n","\n","    except Exception as e:\n","        logging.error(f\"GPT-4 응답 생성 중 오류 발생: {str(e)}\")\n","        return f\"죄송합니다. GPT-4 응답을 생성하는 중에 오류가 발생했습니다: {str(e)}\"\n"],"metadata":{"id":"QhbM93p1bx6D"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 8. 전체 쿼리 처리 함수 (process_query) -> 여기도 보기"],"metadata":{"id":"0wucD8Czmsdg"}},{"cell_type":"code","source":["def process_query(query: str) -> str:\n","    start_time = time.time()\n","    logging.info(f\"처리 중인 쿼리: {query}\")\n","\n","    category, disease, intent = match_metadata(query, DISEASE_CATEGORIES, DISEASES, INTENTS)\n","    logging.info(f\"추출된 메타데이터: 카테고리={category}, 질병={disease}, 의도={intent}\")\n","    print(f\"추출된 메타데이터: 카테고리={category}, 질병={disease}, 의도={intent}\")\n","\n","    expanded_queries = expand_query(query)\n","    logging.info(f\"확장된 쿼리: {expanded_queries}\")\n","\n","    try:\n","        all_documents = vector_store.similarity_search(query, k=20)\n","\n","        if not all_documents:\n","            logging.warning(\"Qdrant에서 검색 결과가 없습니다.\")\n","            return generate_gpt4_response(query)\n","\n","        valid_documents = []\n","        for doc in all_documents:\n","            content = doc.payload.get('답변', None)\n","            if content is None:\n","                logging.warning(f\"문서에 유효하지 않은 데이터가 포함되어 있습니다: {doc.payload}\")\n","                continue\n","            if content.strip():\n","                valid_documents.append({\n","                    \"content\": content,\n","                    \"metadata\": doc.payload\n","                })\n","\n","        if not valid_documents:\n","            logging.warning(\"유효한 문서가 없습니다.\")\n","            return generate_gpt4_response(query)\n","\n","        best_match = valid_documents[0]\n","        context = best_match['content']\n","        metadata = best_match['metadata']\n","\n","        end_time = time.time()\n","        processing_time = end_time - start_time\n","        logging.info(f\"처리 시간: {processing_time:.2f}초\")\n","\n","        return generate_gpt4_response(query, context=context, metadata=metadata)\n","\n","    except Exception as e:\n","        # logging.error(f\"쿼리 처리 중 오류 발생: {str(e)}\")\n","        return generate_gpt4_response(query)\n"],"metadata":{"id":"NdGfDbwibypJ"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 9. 시스템 평가 함수 (evaluate_system)"],"metadata":{"id":"poEijDK4munI"}},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"beDjCS_4XeUe","executionInfo":{"status":"ok","timestamp":1724327727509,"user_tz":-540,"elapsed":38102,"user":{"displayName":"gahee lee","userId":"08208205269460621834"}},"outputId":"ccc40553-edbe-4312-a458-d5b33788429b"},"outputs":[{"output_type":"stream","name":"stdout","text":["추출된 메타데이터: 카테고리=응급질환, 질병=고혈압, 의도=증상\n","질문: 응급한 고혈압 증상이 궁금해요\n","답변: 응급한 고혈압 증상에는 다음과 같은 것들이 포함됩니다:\n","\n","1. **심한 두통**: 고혈압의 가장 흔한 증상 중 하나로, 갑작스럽고 심한 두통이 발생할 수 있습니다.\n","2. **혼란 또는 의식 변화**: 고혈압으로 인해 뇌에 혈류가 제대로 공급되지 않을 때 혼란이나 의식 수준의 변화가 일어\n","처리 시간: 5.29초\n","--------------------------------------------------\n","추출된 메타데이터: 카테고리=None, 질병=고혈압, 의도=증상\n","질문: 고혈압 증상이 궁금해요\n","답변: 고혈압의 증상은 종종 뚜렷하지 않아 \"조용한 살인자\"라고도 불립니다. 많은 사람들이 명백한 증상을 느끼지 않을 수 있습니다. 그러나 일부 사람들은 고혈압이 상당히 높을 때 다음과 같은 증상을 경험할 수 있습니다:\n","\n","- 두통\n","- 숨가쁨\n","- 코피\n","- 어지러움 또\n","처리 시간: 6.11초\n","--------------------------------------------------\n","추출된 메타데이터: 카테고리=None, 질병=고혈압, 의도=None\n","질문: 고혈압에 대해 알고 싶어요\n","답변: 고혈압은 혈액이 동맥벽에 가하는 압력이 높아져 지속적으로 혈압이 140/90mmHg 이상으로 유지되는 상태를 말합니다. 고혈압은 특별한 증상이 없는 경우가 많아 '조용한 살인자'라고도 불립니다. 장기간 방치하면 심장병, 뇌졸중, 신장 질환 등의 심각한 합병증을 일으\n","처리 시간: 10.41초\n","--------------------------------------------------\n","추출된 메타데이터: 카테고리=None, 질병=고혈압, 의도=None\n","질문: 머리가 어지럽고 가슴통증이 있고 시야에 문제가 있고 코피가나\n","답변: 머리가 어지럽고, 가슴 통증이 있으며, 시야에 문제가 발생하고 코피가 나는 증상은 여러 가지 건강 문제를 나타낼 수 있습니다. 이러한 증상들은 단일 질환에서부터 여러 조건의 복합적인 결과일 수 있으며, 간과해서는 안 될 심각한 상태일 수도 있습니다. 주요 고려 사항은 다음과 같습니다:\n","\n","1. 고혈\n","처리 시간: 10.51초\n","--------------------------------------------------\n","추출된 메타데이터: 카테고리=None, 질병=None, 의도=None\n","질문: 아 어지러운데 이게뭐지\n","답변: 어지러움은 다양한 원인으로 발생할 수 있습니다. 가장 흔한 원인 중 일부는 다음과 같습니다:\n","\n","1. **이석증**: 내이의 작은 결정체들이 정상 위치를 벗어나 균형 감각에 영향을 미칩니다.\n","2. **혈압 변동**: 너무 낮거나 높은 혈압은 어지러움을 유발할 수 있습니다.\n","3. **탈수 또는 영양 부족\n","처리 시간: 5.69초\n","--------------------------------------------------\n","평균 처리 시간: 7.60초\n"]}],"source":["import time\n","import logging\n","\n","def evaluate_system():\n","    test_queries = [\n","        \"응급한 고혈압 증상이 궁금해요\", # 카테고리 + 질병 + 의도\n","        \"고혈압 증상이 궁금해요\", # 질병 + 의도\n","        \"고혈압에 대해 알고 싶어요\", # 질병\n","        \"머리가 어지럽고 가슴통증이 있고 시야에 문제가 있고 코피가나\", # 다 없고 증상만 나열\n","        \"아 어지러운데 이게뭐지\" # 모호한 답변 대답 하면 안됨\n","    ]\n","\n","    total_time = 0\n","    for query in test_queries:\n","        try:\n","            start_time = time.time()\n","            response = process_query(query)\n","            end_time = time.time()\n","\n","            processing_time = end_time - start_time\n","            total_time += processing_time\n","\n","            print(f\"질문: {query}\")\n","            print(f\"답변: {response}\")\n","            print(f\"처리 시간: {processing_time:.2f}초\")\n","            print(\"-\" * 50)\n","\n","        except Exception as e:\n","            logging.error(f\"쿼리 처리 중 오류 발생: {str(e)}\")\n","\n","    avg_time = total_time / len(test_queries)\n","    print(f\"평균 처리 시간: {avg_time:.2f}초\")\n","\n","if __name__ == \"__main__\":\n","    evaluate_system()\n"]},{"cell_type":"markdown","source":["문제점 :  메타데이터 추출은 되는데 쿼리에서 메타데이터 인식을 제대로 못한다\n","아까 강사님이 이야기 하셨던 것처럼 좀 빡세게 인식하는듯  \n","정확한 단어가 아니면 인식하지 않는듯 하다  \n","그래서 아마 카테고리 같은 부분은 인식하기 쉽지 않을듯 하다  \n","질병 같은 부분을 보고 카테고리를 유추할듯  \n","\n","대처방법  \n","컷을 내린다  \n","인식을 위해 자연어 전처리 과정을 더 넣는다  \n","\n","하튼 질문을 하나씩 단어가 덜 들어간 것을 보면  \n","메타 데이터 인식이 을 하나씩 덜 하는 모습이 보임\n","\n","또 max_length 좀 늘려야 할듯 잘림  \n","\n","그리고 답변이 나오면 답변의 메타데이터로 바꿔주는것도 괜찮을듯  "],"metadata":{"id":"VJ7JR6lnyg4D"}},{"cell_type":"markdown","source":["# 틀린부분 고치기"],"metadata":{"id":"TOdyXptlo_Y7"}},{"cell_type":"code","source":[],"metadata":{"id":"r1z-1iG2pB5D"},"execution_count":null,"outputs":[]}]}